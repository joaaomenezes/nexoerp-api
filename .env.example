# Modelo do arquivo .env — COPIE este arquivo para um novo arquivo chamado ".env"
# e preencha com os seus valores. O .env de verdade NÃO sobe pro GitHub (tem segredos).

# Conexão com o banco PostgreSQL.
# Formato: postgresql://USUARIO:SENHA@HOST:PORTA/NOME_DO_BANCO?schema=public
# Ex.: usuário "postgres", senha "1234", banco "nexoerp" na sua máquina:
DATABASE_URL="postgresql://postgres:SUA_SENHA@localhost:5432/nexoerp?schema=public"

# Frase secreta usada para assinar os tokens de login (JWT).
# Pode ser qualquer texto longo e aleatório. NÃO compartilhe.
JWT_SECRET="troque-por-uma-frase-secreta-bem-grande-e-aleatoria"

# Porta em que a API vai rodar (o frontend espera a 3333).
PORT=3333
